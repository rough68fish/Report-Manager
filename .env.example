# ── Database selector ─────────────────────────────────────────────────────────
# Set to 'oracle' for production or Oracle dev testing.
# Set to 'postgres' for lightweight local development.
DB_TYPE=postgres

# ── PostgreSQL (used when DB_TYPE=postgres) ───────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=report_catalog
POSTGRES_USER=catalog
POSTGRES_PASSWORD=catalog_password

# ── Oracle (used when DB_TYPE=oracle) ─────────────────────────────────────────
# Oracle Free runs the app schema in FREEPDB1 (the pluggable database).
# After first container start, run oracle-init/01_create_user.sql to provision
# the catalog_user account, or adjust these to match your production Oracle setup.
ORACLE_HOST=oracle
ORACLE_PORT=1521
ORACLE_SERVICE=FREEPDB1
ORACLE_USER=catalog_user
ORACLE_PASSWORD=catalog_password

# ── Okta ──────────────────────────────────────────────────────────────────────
OKTA_DOMAIN=https://integrator-xxxxxxx.okta.com
OKTA_ISSUER=https://integrator-xxxxxxx.okta.com/oauth2/default
OKTA_AUDIENCE=api://default

# ── Okta — React SPA (Single-Page Application type in Okta) ──────────────────
# Create: Applications → Create App Integration → OIDC → Single-Page Application
# Redirect URI:  http://localhost:5173/login/callback
# Sign-out URI:  http://localhost:5173
VITE_OKTA_ISSUER=https://integrator-xxxxxxx.okta.com/oauth2/default
VITE_OKTA_CLIENT_ID=0oaxxxxxxxxxxxxxxx
VITE_OKTA_REDIRECT_URI=http://localhost:5173/login/callback

# ── API ───────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173
