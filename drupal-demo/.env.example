# Copy this file to .env before running docker compose up
# cp .env.example .env

# Database credentials
MYSQL_ROOT_PASSWORD=rootpassword123
MYSQL_DATABASE=drupal
MYSQL_USER=drupal
MYSQL_PASSWORD=drupal_password123

# Drupal admin account (used by setup.sh)
DRUPAL_ADMIN_USER=admin
DRUPAL_ADMIN_PASSWORD=admin_password123
DRUPAL_ADMIN_EMAIL=admin@example.com
DRUPAL_SITE_NAME=Report Catalog Demo

# ── Okta SSO (fill in after completing OKTA_SETUP.md) ──────────────────────
# Your Okta developer domain — no trailing slash
OKTA_DOMAIN=https://dev-xxxxxxxx.okta.com

# Drupal SSO Web Application (handles human user login)
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# Node.js catalog API Service Application (machine-to-machine)
OKTA_API_CLIENT_ID=
OKTA_API_CLIENT_SECRET=
